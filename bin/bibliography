"""
Bibliography generator CLI entry point.
"""

import sys
from argparse import ArgumentParser
from src.core.lexer import OptimizedLexer
from src.core.parser import OptimizedParser
from src.core.generator import OptimizedBibTeXGenerator, BibEntry
from src.features.formatters import FormattersFactory, CitationFormat
from src.utils.i18n import I18nManager, Language


class OptimizedBibliographyGenerator:
    """Optimized bibliography generator with fast processing."""
    
    def __init__(self):
        self.parser = OptimizedParser()
        self.lexer_class = OptimizedLexer
        self.generator = OptimizedBibTeXGenerator()
        self.i18n = I18nManager()
        self.factory = FormattersFactory()
    
    def process_file(self, input_file: str, output_file: str, format_name: str = "bibtex") -> int:
        """Process bibliography file with optimized pipeline."""
        try:
            # Read input
            with open(input_file, 'r', encoding='utf-8') as f:
                references = f.read().split('\n\n')
            
            # Process entries
            entries = []
            for ref in references:
                if ref.strip():
                    parsed = self.parser.parse(ref)
                    
                    entry = BibEntry(
                        entry_id=parsed.entry_id,
                        entry_type=parsed.entry_type,
                        authors=parsed.authors,
                        title=parsed.title,
                        journal=parsed.journal,
                        year=parsed.year,
                        volume=parsed.volume,
                        number=parsed.number,
                        pages=parsed.pages,
                        publisher=parsed.publisher,
                        school=parsed.school,
                    )
                    entries.append(entry)
            
            # Generate output
            if format_name.lower() == "bibtex":
                output = self.generator.generate_batch(entries)
            else:
                formatter = self.factory.get_formatter(format_name)
                output_lines = []
                for entry in entries:
                    entry_dict = {
                        'entry_id': entry.entry_id,
                        'entry_type': entry.entry_type,
                        'author': entry.authors,
                        'title': entry.title,
                        'journal': entry.journal,
                        'year': entry.year,
                        'volume': entry.volume,
                        'number': entry.number,
                        'page': entry.pages,
                        'publisher': entry.publisher,
                        'school': entry.school,
                    }
                    output_lines.append(formatter.format(entry_dict))
                output = '\n\n'.join(output_lines)
            
            # Write output
            with open(output_file, 'w', encoding='utf-8') as f:
                f.write(output)
            
            print(f"✓ Processed {len(entries)} references")
            print(f"✓ Output written to {output_file}")
            return 0
        
        except Exception as e:
            print(f"✗ Error: {e}", file=sys.stderr)
            return 1
    
    def main(self):
        """Main CLI entry point."""
        parser = ArgumentParser(description="Optimized Bibliography Generator")
        
        parser.add_argument('input', help='Input file with references')
        parser.add_argument('output', help='Output file for bibliography')
        parser.add_argument('--format', '-f', default='bibtex',
                          choices=['bibtex', 'ieee', 'apa', 'chicago', 'mla'],
                          help='Output format (default: bibtex)')
        parser.add_argument('--language', '-l', default='en',
                          choices=['en', 'fr', 'es', 'de', 'zh'],
                          help='Output language (default: en)')
        
        args = parser.parse_args()
        
        # Set language
        try:
            lang = Language(args.language)
            self.i18n.set_language(lang)
        except ValueError:
            pass
        
        return self.process_file(args.input, args.output, args.format)


if __name__ == '__main__':
    gen = OptimizedBibliographyGenerator()
    sys.exit(gen.main())
